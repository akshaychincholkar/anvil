REM Copy this file to .env.local (same folder) and fill in real values.
REM .env.local is gitignored — never commit real secrets.
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
BASE_URL=http://localhost:8000
ANVIL_SECRET=any-random-string-for-local-dev
